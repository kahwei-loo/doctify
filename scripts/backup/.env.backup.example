# ===========================================
# Doctify Backup Configuration
# ===========================================
# Copy this file to .env.backup and configure your settings
# IMPORTANT: Never commit .env.backup to version control!

# ===========================================
# Database Connection
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=doctify_development
POSTGRES_USER=doctify
# Use Docker secrets in production, env var only for local dev
POSTGRES_PASSWORD=your_secure_password_here

REDIS_HOST=localhost
REDIS_PORT=6379
# Leave empty if no Redis authentication
REDIS_PASSWORD=

# ===========================================
# Backup Storage
# ===========================================
# Local backup directory (will be created if not exists)
BACKUP_DIR=/var/backups/doctify
# Temporary directory for backup processing
BACKUP_TEMP_DIR=/tmp/doctify-backup

# ===========================================
# Encryption (GPG/AES256)
# ===========================================
# Enable encryption for backups (recommended for production)
BACKUP_ENCRYPTION_ENABLED=true
# GPG recipient email/key ID for asymmetric encryption
# Leave empty to use symmetric encryption with passphrase
GPG_RECIPIENT=
# Passphrase for symmetric encryption (if GPG_RECIPIENT is empty)
# Generate with: openssl rand -base64 32
BACKUP_ENCRYPTION_KEY=your_32_char_encryption_key_here

# ===========================================
# Retention Policy
# ===========================================
# Number of daily backups to keep
RETENTION_DAILY=7
# Number of weekly backups to keep (created on Sundays)
RETENTION_WEEKLY=4
# Number of monthly backups to keep (created on 1st of month)
RETENTION_MONTHLY=3

# ===========================================
# Offsite Backup (3-2-1 Rule)
# ===========================================
# Enable offsite backup sync
OFFSITE_ENABLED=false
# SSH connection string for offsite server
OFFSITE_SSH_HOST=user@backup-server.example.com
# Remote directory path
OFFSITE_SSH_PATH=/backups/doctify
# SSH key path (optional, uses default if empty)
OFFSITE_SSH_KEY=

# ===========================================
# Notifications
# ===========================================
# Enable email notifications
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_TO=admin@example.com
NOTIFY_EMAIL_FROM=backup@doctify.local
SMTP_HOST=localhost
SMTP_PORT=25

# Enable Slack notifications
NOTIFY_SLACK_ENABLED=false
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# ===========================================
# Logging
# ===========================================
# Log file location
LOG_FILE=/var/log/doctify/backup.log
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ===========================================
# Performance
# ===========================================
# Compression level for gzip (1-9, higher = smaller but slower)
COMPRESSION_LEVEL=6
# Number of parallel jobs for pg_dump (0 = auto-detect)
PARALLEL_JOBS=0
