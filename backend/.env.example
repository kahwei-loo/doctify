# ============================================================================
# Doctify Backend Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# Different environments can use .env.development, .env.staging, .env.production

# ============================================================================
# Application Settings
# ============================================================================

# Application environment: development, staging, or production
ENVIRONMENT=development

# Enable debug mode (NEVER use true in production)
DEBUG=true

# Application name and version
APP_NAME=Doctify
APP_VERSION=1.0.0

# API version prefix
API_V1_STR=/api/v1

# Server configuration
HOST=0.0.0.0
PORT=8000

# ============================================================================
# Database Settings - PostgreSQL
# ============================================================================

# PostgreSQL connection settings
# Development: localhost
# Docker: doctify-postgres (service name)
# Production: your-production-host
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=doctify
POSTGRES_PASSWORD=doctify_dev_password
POSTGRES_DB=doctify_development

# Connection pool settings
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# SSL mode for PostgreSQL connection
# Options: disable, allow, prefer, require, verify-ca, verify-full
# Development: disable
# Production: require or verify-full
POSTGRES_SSL_MODE=disable

# ============================================================================
# Cache Settings - Redis
# ============================================================================

# Redis connection URL
# Format: redis://[:password@]host:port/db
REDIS_URL=redis://localhost:6379/0

# Redis connection pool size
REDIS_MAX_CONNECTIONS=50

# Default cache TTL in seconds (1 hour)
CACHE_TTL=3600

# ============================================================================
# Task Queue Settings - Celery
# ============================================================================

# Celery broker URL (typically Redis)
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery result backend URL
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Task time limits in seconds
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=270

# ============================================================================
# Authentication Settings - JWT
# ============================================================================

# REQUIRED: Secret key for JWT token generation
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-this-in-production

# JWT algorithm
ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# Security Settings
# ============================================================================

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# Login security
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ============================================================================
# CORS Settings
# ============================================================================

# Allowed CORS origins (comma-separated)
# Development: http://localhost:3000,http://localhost:3003
# Production: https://your-domain.com,https://app.your-domain.com
BACKEND_CORS_ORIGINS=http://localhost:3003

# CORS configuration
BACKEND_CORS_ALLOW_CREDENTIALS=true
BACKEND_CORS_ALLOW_METHODS=*
BACKEND_CORS_ALLOW_HEADERS=*

# ============================================================================
# AI Provider Settings
# ============================================================================

# OpenAI API configuration
# For OpenRouter: https://openrouter.ai/api/v1
# For OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Your OpenAI API key
OPENAI_API_KEY=your-api-key-here

# AI model to use
# OpenRouter: openai/gpt-4, anthropic/claude-3-opus, etc.
# OpenAI: gpt-4, gpt-3.5-turbo
AI_MODEL=openai/gpt-4

# AI model parameters
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=4000
AI_TIMEOUT=60

# Cohere API key (for reranking)
COHERE_API_KEY=your-cohere-api-key-here

# ============================================================================
# AI Gateway Settings (LiteLLM)
# ============================================================================
# Per-purpose model routing — uses LiteLLM model ID format
# OpenRouter prefix: openrouter/<vendor>/<model>

# Default chat/generation model
AI_GATEWAY_CHAT_MODEL=openrouter/openai/gpt-4

# Fast/cheap model for judges, classifiers, evaluation
AI_GATEWAY_CHAT_FAST_MODEL=openrouter/openai/gpt-4o-mini

# Embedding model
AI_GATEWAY_EMBEDDING_MODEL=openrouter/openai/text-embedding-3-small

# Primary vision model for OCR/document processing
AI_GATEWAY_VISION_MODEL=openrouter/qwen/qwen3-vl-8b-instruct

# Vision model escalation chain (comma-separated, tried in order on low confidence)
AI_GATEWAY_VISION_ESCALATION=openrouter/qwen/qwen3-vl-8b-instruct,openrouter/qwen/qwen3-vl-32b-instruct,openrouter/google/gemini-3-flash-preview

# Intent classification model
AI_GATEWAY_CLASSIFIER_MODEL=openrouter/openai/gpt-4o-mini

# Reranker model
AI_GATEWAY_RERANKER_MODEL=cohere/rerank-v3.5

# ============================================================================
# File Upload Settings
# ============================================================================

# Page limits for documents
MAX_PAGES_HARD=30
MAX_PAGES_WARN=10

# Maximum file size in megabytes
MAX_FILE_SIZE_MB=50

# Allowed file types (comma-separated MIME types)
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/tiff,image/webp

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.tiff,.webp

# ============================================================================
# Storage Settings
# ============================================================================

# Storage backend: local or s3
STORAGE_BACKEND=local

# Local storage directory (if using local storage)
UPLOAD_DIR=./uploads

# S3 Configuration (if using S3 storage)
# S3-compatible endpoint URL (leave empty for AWS S3)
# MinIO example: http://localhost:9000
# DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
S3_ENDPOINT_URL=

# S3 credentials
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# S3 bucket and region
S3_BUCKET_NAME=doctify-uploads
S3_REGION=us-east-1

# ============================================================================
# WebSocket Settings
# ============================================================================

# WebSocket message queue size
WS_MESSAGE_QUEUE_SIZE=100

# WebSocket heartbeat interval in seconds
WS_HEARTBEAT_INTERVAL=30

# ============================================================================
# Monitoring & Logging Settings
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=json

# Prometheus metrics
ENABLE_PROMETHEUS=false
PROMETHEUS_PORT=9090

# ============================================================================
# Environment-Specific Notes
# ============================================================================

# Development Environment (.env.development):
# - Use DEBUG=true
# - Use local PostgreSQL and Redis (or Docker services)
# - Use local file storage
# - Relaxed CORS settings
# - POSTGRES_SSL_MODE=disable

# Staging Environment (.env.staging):
# - Use DEBUG=false
# - Use production-like databases
# - Test with S3 storage
# - Production-like security settings
# - POSTGRES_SSL_MODE=require

# Production Environment (.env.production):
# - Use DEBUG=false (REQUIRED)
# - Use production databases with authentication
# - Use S3 storage with proper credentials
# - Strict CORS origins
# - Strong SECRET_KEY
# - Enable monitoring and logging
# - POSTGRES_SSL_MODE=verify-full
