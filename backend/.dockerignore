# ==========================================
# Backend .dockerignore
# ==========================================
# Exclude files and directories that shouldn't be in Docker images

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
tests/
*.test.py
test_*.py

# Development tools
.mypy_cache/
.ruff_cache/
.black_cache/

# Documentation
docs/
*.md
README.md
CHANGELOG.md
CONTRIBUTING.md

# Git
.git/
.gitignore
.gitattributes

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*
!.env.example

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp

# Build artifacts
build/
dist/
*.egg-info/

# Database
*.db
*.sqlite3

# Uploads (should use external storage in production)
uploads/
temp_uploads/

# Docker files (don't need these in the image)
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# Requirements files (test only - dev.txt needed for Dockerfile.dev)
requirements/test.txt

# Scripts
scripts/
*.sh

# Monitoring and profiling
.pytest_profiling/
prof/
