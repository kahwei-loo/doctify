# ===========================================
# Doctify Production Environment Variables
# ===========================================
# Copy this file to .env.prod and fill in your actual values
# Use with: docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# IMPORTANT: This file works with Docker Compose environment variable substitution.
# For sensitive credentials, use Docker secrets (see docker-compose.prod.yml).

# ============================================================================
# Domain & SSL Configuration
# ============================================================================

# Your production domain (used for Traefik routing)
DOMAIN=example.com

# Email for Let's Encrypt SSL certificate notifications
ACME_EMAIL=admin@example.com

# ============================================================================
# Application Version
# ============================================================================

# Docker image version tag (use semantic versioning)
VERSION=1.0.1

# ============================================================================
# PostgreSQL Configuration
# ============================================================================

# PostgreSQL credentials
# NOTE: In production, POSTGRES_PASSWORD should use Docker secrets
# Create secret: echo "your-password" | docker secret create postgres_password -
POSTGRES_USER=doctify
POSTGRES_DB=doctify_production
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32

# ============================================================================
# Redis Configuration
# ============================================================================

# Redis password
# NOTE: In production, use Docker secrets
# Create secret: echo "your-password" | docker secret create redis_password -
REDIS_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32

# ============================================================================
# Backend Configuration
# ============================================================================

# REQUIRED: Secret key for JWT tokens
# Generate with: openssl rand -hex 32
# NOTE: In production, use Docker secrets
# Create secret: echo "your-key" | docker secret create secret_key -
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# CORS allowed origins (comma-separated, no spaces)
# Production: Your actual domain URLs
CORS_ORIGINS=https://doctify.example.com,https://example.com

# Application environment
ENVIRONMENT=production

# ============================================================================
# AI Provider Configuration
# ============================================================================

# OpenAI API configuration
# For OpenRouter: https://openrouter.ai/api/v1
# For OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Your OpenAI API key
# NOTE: In production, use Docker secrets
# Create secret: echo "sk-..." | docker secret create openai_api_key -
OPENAI_API_KEY=your-openai-api-key-here

# AI model to use
# OpenRouter: openai/gpt-4, anthropic/claude-3-opus, etc.
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
AI_MODEL=gpt-4

# ============================================================================
# Traefik Dashboard Configuration
# ============================================================================

# Traefik dashboard basic auth (generate with: htpasswd -nb admin your-password)
# Format: username:password-hash
# Example: admin:$apr1$ruca84Hq$mbjdMZBAG.KWn7vfN/SNK/
TRAEFIK_DASHBOARD_USER=admin:your-htpasswd-hash-here

# ============================================================================
# Monitoring Configuration (Optional)
# ============================================================================

# Grafana admin password (if using Grafana)
GRAFANA_PASSWORD=your-grafana-password-here

# ============================================================================
# Docker Secrets Setup (Production)
# ============================================================================
#
# For enhanced security, use Docker secrets instead of environment variables
# for sensitive credentials. Create secrets with:
#
#   echo "your-postgres-password" | docker secret create postgres_password -
#   echo "your-redis-password" | docker secret create redis_password -
#   echo "your-secret-key" | docker secret create secret_key -
#   echo "your-openai-key" | docker secret create openai_api_key -
#
# The docker-compose.prod.yml is configured to use these secrets.
#
# ============================================================================
# Security Checklist
# ============================================================================
#
# [ ] All passwords changed from defaults (use: openssl rand -base64 32)
# [ ] SECRET_KEY generated (use: openssl rand -hex 32)
# [ ] Docker secrets created for sensitive values
# [ ] CORS_ORIGINS set to actual production domains only
# [ ] AI API credentials configured
# [ ] DOMAIN set to your actual domain
# [ ] ACME_EMAIL set for Let's Encrypt notifications
# [ ] Traefik dashboard password configured (htpasswd)
# [ ] Firewall configured (allow only 80, 443, SSH)
# [ ] VPS hardening completed (SSH keys, fail2ban, etc.)
# [ ] Backup scripts configured and tested
# [ ] Monitoring and alerting configured
#
# ============================================================================
# Deployment Commands
# ============================================================================
#
# 1. Create Docker secrets:
#    ./scripts/setup-secrets.sh  (or manually as shown above)
#
# 2. Deploy the stack:
#    docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# 3. View logs:
#    docker-compose -f docker-compose.prod.yml logs -f
#
# 4. Check health:
#    curl https://api.your-domain.com/health
#
# ============================================================================
