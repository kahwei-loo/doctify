# ============================================================================
# Doctify Frontend Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# Different environments: .env.development.local, .env.staging.local, .env.production.local

# ============================================================================
# API Configuration
# ============================================================================

# Backend API base URL
# Development: http://localhost:50080
# Production: https://api.your-domain.com
VITE_API_BASE_URL=http://localhost:50080

# API version prefix (should match backend API_V1_STR)
VITE_API_V1_PREFIX=/api/v1

# WebSocket URL
# Development: ws://localhost:50080
# Production: wss://api.your-domain.com
VITE_WS_BASE_URL=ws://localhost:50080

# ============================================================================
# Application Settings
# ============================================================================

# Application environment: development, staging, or production
VITE_APP_ENV=development

# Application name
VITE_APP_NAME=Doctify

# Application version
VITE_APP_VERSION=1.0.0

# Enable debug mode (NEVER use in production)
VITE_DEBUG=true

# ============================================================================
# Feature Flags
# ============================================================================

# Enable file upload feature
VITE_FEATURE_FILE_UPLOAD=true

# Enable real-time updates via WebSocket
VITE_FEATURE_REALTIME=true

# Enable export functionality
VITE_FEATURE_EXPORT=true

# Enable project management
VITE_FEATURE_PROJECTS=true

# Enable API key management
VITE_FEATURE_API_KEYS=true

# Use mock data for Knowledge Base (development only)
VITE_USE_MOCK_KB=false

# ============================================================================
# File Upload Settings
# ============================================================================

# Maximum file size in MB (should match backend MAX_FILE_SIZE_MB)
VITE_MAX_FILE_SIZE_MB=50

# Maximum pages per document (should match backend MAX_PAGES_HARD)
VITE_MAX_PAGES=30

# Warning threshold for page count
VITE_MAX_PAGES_WARN=10

# Allowed file extensions (comma-separated)
VITE_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.tiff,.webp

# ============================================================================
# UI/UX Settings
# ============================================================================

# Items per page in tables
VITE_ITEMS_PER_PAGE=20

# Debounce delay for search inputs (milliseconds)
VITE_SEARCH_DEBOUNCE_MS=300

# Toast notification duration (milliseconds)
VITE_TOAST_DURATION_MS=5000

# Auto-refresh interval for document list (milliseconds, 0 to disable)
VITE_AUTO_REFRESH_INTERVAL_MS=30000

# ============================================================================
# Performance Settings
# ============================================================================

# Enable React Query devtools
VITE_ENABLE_DEVTOOLS=true

# API request timeout (milliseconds)
VITE_API_TIMEOUT_MS=30000

# Maximum retry attempts for failed API requests
VITE_API_MAX_RETRIES=3

# Retry delay for failed requests (milliseconds)
VITE_API_RETRY_DELAY_MS=1000

# ============================================================================
# Authentication Settings
# ============================================================================

# Token storage key in localStorage
VITE_TOKEN_STORAGE_KEY=doctify_token

# Refresh token storage key
VITE_REFRESH_TOKEN_STORAGE_KEY=doctify_refresh_token

# Auto-logout on token expiry
VITE_AUTO_LOGOUT=true

# Session timeout warning (minutes before expiry)
VITE_SESSION_TIMEOUT_WARNING_MIN=5

# ============================================================================
# Analytics & Monitoring (Optional)
# ============================================================================

# Google Analytics tracking ID (optional)
VITE_GA_TRACKING_ID=

# Sentry DSN for error tracking (optional)
VITE_SENTRY_DSN=

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# ============================================================================
# Build Settings
# ============================================================================

# Source map generation for debugging
# development: true, production: false
VITE_GENERATE_SOURCEMAP=true

# Bundle size warnings
VITE_BUNDLE_SIZE_LIMIT_KB=500

# ============================================================================
# Environment-Specific Notes
# ============================================================================

# Development Environment (.env.development.local):
# - Use VITE_DEBUG=true
# - Use localhost API URLs
# - Enable all feature flags for testing
# - Enable devtools
# - Generate source maps

# Staging Environment (.env.staging.local):
# - Use VITE_DEBUG=false
# - Use staging API URLs
# - Test production-like settings
# - Disable devtools
# - Optional source maps

# Production Environment (.env.production.local):
# - Use VITE_DEBUG=false (REQUIRED)
# - Use production API URLs (HTTPS/WSS)
# - Disable unnecessary features
# - Disable devtools
# - No source maps
# - Enable error tracking (Sentry)
# - Enable analytics if needed

# ============================================================================
# Notes
# ============================================================================

# 1. All VITE_* variables are embedded at build time and exposed to client-side code
# 2. Never include sensitive information (API keys, secrets) in frontend env vars
# 3. Use .env.local for local overrides (not committed to git)
# 4. Variables without VITE_ prefix are NOT available in the application
