# ============================================================================
# Doctify Frontend — Production Build Defaults
# ============================================================================
# These values are used when building with `npm run build` (mode=production).
# Override per-deployment values in .env.production.local (gitignored).

# ============================================================================
# API Configuration (OVERRIDE in .env.production.local)
# ============================================================================

# Backend API base URL — MUST be overridden per deployment
VITE_API_BASE_URL=https://api.example.com

# WebSocket URL — MUST be overridden per deployment
VITE_WS_BASE_URL=wss://api.example.com

# API version prefix
VITE_API_V1_PREFIX=/api/v1

# ============================================================================
# Application Settings
# ============================================================================

VITE_APP_ENV=production
VITE_APP_NAME=Doctify
VITE_APP_VERSION=1.0.0
VITE_DEBUG=false

# ============================================================================
# Feature Flags
# ============================================================================

VITE_FEATURE_FILE_UPLOAD=true
VITE_FEATURE_REALTIME=true
VITE_FEATURE_EXPORT=true
VITE_FEATURE_PROJECTS=true
VITE_FEATURE_API_KEYS=true
VITE_USE_MOCK_KB=false

# ============================================================================
# File Upload Settings
# ============================================================================

VITE_MAX_FILE_SIZE_MB=50
VITE_MAX_PAGES=30
VITE_MAX_PAGES_WARN=10
VITE_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.tiff,.webp

# ============================================================================
# UI/UX Settings
# ============================================================================

VITE_ITEMS_PER_PAGE=20
VITE_SEARCH_DEBOUNCE_MS=300
VITE_TOAST_DURATION_MS=5000
VITE_AUTO_REFRESH_INTERVAL_MS=30000

# ============================================================================
# Performance Settings
# ============================================================================

VITE_ENABLE_DEVTOOLS=false
VITE_API_TIMEOUT_MS=30000
VITE_API_MAX_RETRIES=3
VITE_API_RETRY_DELAY_MS=1000

# ============================================================================
# Authentication Settings
# ============================================================================

VITE_TOKEN_STORAGE_KEY=doctify_token
VITE_REFRESH_TOKEN_STORAGE_KEY=doctify_refresh_token
VITE_AUTO_LOGOUT=true
VITE_SESSION_TIMEOUT_WARNING_MIN=5

# ============================================================================
# Analytics & Monitoring
# ============================================================================

VITE_GA_TRACKING_ID=
VITE_SENTRY_DSN=
VITE_ENABLE_PERFORMANCE_MONITORING=false

# ============================================================================
# Build Settings
# ============================================================================

VITE_GENERATE_SOURCEMAP=false
VITE_BUNDLE_SIZE_LIMIT_KB=500
