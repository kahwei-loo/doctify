# ==========================================
# Frontend .dockerignore
# ==========================================
# Exclude files and directories that shouldn't be in Docker images

# Dependencies (will be installed during build)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/
tests/
test/
*.spec.ts
*.spec.tsx
*.test.ts
*.test.tsx
__tests__/
__mocks__/
.jest/
playwright-report/
test-results/

# Build outputs (will be generated during build)
dist/
build/
.vite/
.cache/

# Development
.env.local
.env.development
.env.test
.env.production.local

# Environment files
.env
.env.*
!.env.example

# Documentation
docs/
*.md
README.md
CHANGELOG.md
CONTRIBUTING.md

# Git
.git/
.gitignore
.gitattributes

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.editorconfig

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Logs
logs/
*.log

# TypeScript
*.tsbuildinfo

# ESLint and Prettier
.eslintcache
.prettierignore

# Package manager lock files (keep one, ignore others)
yarn.lock
pnpm-lock.yaml
# Keep: package-lock.json

# Docker files
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore
nginx.conf.template

# Storybook
storybook-static/
.storybook/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Editor directories
.history/

# Miscellaneous
.vercel
.netlify
.next/
out/

# Source maps (if not needed in production)
*.map
